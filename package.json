{
  "name": "trading-bot-ml",
  "version": "0.1.0",
  "description": "Trading bot scaffold for a TradingView-based strategy (TypeScript)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "find-conid": "node src/tools/find-ib-conid.cjs",
    "tsnode": "node --loader ts-node/esm",
    "refresh-cookies": "node --loader ts-node/esm src/refresh-cookies.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [],
  "author": "defiBuilders",
  "license": "MIT",
  "bin": {
    "ts-node": "bin/ts-node"
  },
  "dependencies": {
    "@pump-fun/pump-sdk": "^1.31.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "@the-convocation/twitter-scraper": "^0.22.1",
    "axios": "^1.5.0",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "cycletls": "^2.0.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "ts-node": "^10.9.1",
    "undici": "^7.24.5",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.5.0",
    "@types/ws": "^8.5.0",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0"
  }
}
